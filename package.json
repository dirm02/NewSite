{
  "name": "lif3line",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:release": "cross-env VITE_APP_ENV=production tsc -b && cross-env VITE_APP_ENV=production vite build",
    "preview": "vite preview",
    "preview:release": "cross-env VITE_APP_ENV=production vite build && cross-env VITE_APP_ENV=production vite preview --port 3001",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:auth": "playwright test --grep @auth",
    "test:e2e:marketplace": "playwright test --grep @marketplace",
    "test:e2e:discovery": "playwright test --grep @discovery",
    "audit:crawl": "tsx scripts/crawl-audit.ts",
    "audit:a11y": "playwright test --grep @health"
  },
